#!/usr/bin/env python3
"""
LumifyDev — Turn LumifyHub kanban cards into async Claude Code sessions.

Point at a board card, kick off a Claude Code session on your VM,
and get status updates posted back to the card automatically.

Requires a LumifyHub account (https://lumifyhub.io) and API key.
"""

import argparse
import sys

from lumifydev_lib import VERSION
from lumifydev_lib.api import APIError
from lumifydev_lib.commands import (
    cmd_boards,
    cmd_cards,
    cmd_checkout,
    cmd_config,
    cmd_run,
    cmd_status,
)
from lumifydev_lib.tui import run_tui


def main():
    parser = argparse.ArgumentParser(
        prog="lumifydev",
        description="Turn LumifyHub kanban cards into async Claude Code sessions.",
    )
    parser.add_argument(
        "--version", action="version", version=f"lumifydev {VERSION}"
    )

    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # menu (interactive TUI — mobile friendly)
    sub_menu = subparsers.add_parser("menu", help="Interactive TUI (mobile friendly)")
    sub_menu.set_defaults(func=run_tui)

    # config
    sub_config = subparsers.add_parser("config", help="Configure LumifyDev")
    sub_config.set_defaults(func=cmd_config)

    # boards
    sub_boards = subparsers.add_parser("boards", help="List boards in workspace")
    sub_boards.set_defaults(func=cmd_boards)

    # cards
    sub_cards = subparsers.add_parser("cards", help="List cards on a board")
    sub_cards.add_argument("board_id", help="Board ID (page ID from lumifydev boards)")
    sub_cards.add_argument("--list", help="Filter by list name (e.g. 'In Progress')")
    sub_cards.set_defaults(func=cmd_cards)

    # run
    sub_run = subparsers.add_parser(
        "run", help="Kick off a Claude Code session for a card"
    )
    sub_run.add_argument("card_id", help="Card ID")
    sub_run.add_argument(
        "--prompt", "-p",
        help="Additional instructions (default: 'Implement this card')",
    )
    sub_run.set_defaults(func=cmd_run)

    # checkout
    sub_checkout = subparsers.add_parser(
        "checkout", help="Checkout the worktree branch for a card"
    )
    sub_checkout.add_argument("card_id", help="Card ID")
    sub_checkout.set_defaults(func=cmd_checkout)

    # status
    sub_status = subparsers.add_parser(
        "status", help="Peek at the VM session output for a card"
    )
    sub_status.add_argument("card_id", help="Card ID")
    sub_status.set_defaults(func=cmd_status)

    args = parser.parse_args()

    if not args.command:
        # No command = launch interactive TUI (mobile friendly)
        run_tui()
        sys.exit(0)

    try:
        args.func(args)
    except APIError as e:
        from lumifydev_lib.display import C_RED, C_RESET
        print(f"{C_RED}API error: {e}{C_RESET}")
        sys.exit(1)
    except KeyboardInterrupt:
        print()
        sys.exit(130)


if __name__ == "__main__":
    main()
